# Copy to .env and fill in values — never commit .env

# Supabase PostgreSQL
# Get from: Supabase Dashboard → Project → Settings → Database → Connection string (URI mode)
# Use the "connection pooling" URL (port 6543) for production
DB_URL=jdbc:postgresql://db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require
DB_USERNAME=postgres
DB_PASSWORD=YOUR_SUPABASE_DB_PASSWORD

# JWT — generate: openssl rand -base64 64
JWT_SECRET=YOUR_BASE64_ENCODED_SECRET_MIN_32_BYTES
JWT_EXPIRATION=86400000

# SMTP — Gmail: use App Password (not account password)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your@gmail.com
MAIL_PASSWORD=your_app_password

# Comma-separated frontend origins allowed by CORS
CORS_ALLOWED_ORIGINS=https://your-app.vercel.app,https://your-app.netlify.app,http://YOUR_OCI_IP
